```gitignore
# Python cache

__pycache__/
*.py[cod]

# Virtual environments

venv/
env/
.venv/

# Environment variables

.env

# IDE files

.vscode/
.idea/

# Jupyter

.ipynb_checkpoints/

# OS files

.DS_Store
Thumbs.db
desktop.ini

# Raw datasets (too large for GitHub)

data/raw/*
!data/raw/.gitkeep

# Model files

models/*
!models/.gitkeep

# Logs

*.log

# Power BI temp files

*.tmp
*.bak
*.pbix.autosave

# Build files

build/
dist/
*.egg-info/

# Cache

.cache/
.pytest_cache/
.mypy_cache/

# Keep deployment-required files tracked

!data/features/clv_scored.csv
!outputs/reports/segment_summary.csv
```
